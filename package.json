{
  "name": "credtrail",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "check:public-docs": "node scripts/check-public-docs.mjs",
    "export:ob3-openapi": "pnpm exec tsx scripts/export-ob3-openapi.mjs",
    "check:ob3-openapi": "pnpm exec tsx scripts/check-ob3-openapi.mjs",
    "cert:preflight": "node scripts/ob3-cert-preflight.mjs",
    "lint": "node scripts/run-oxlint.mjs --deny-warnings",
    "lint:fix": "node scripts/run-oxlint.mjs --fix --fix-suggestions --deny-warnings",
    "format": "pnpm exec oxfmt \"apps/**/*.ts\" \"packages/**/*.ts\" \"vitest.config.ts\"",
    "format:check": "pnpm exec oxfmt --check \"apps/**/*.ts\" \"packages/**/*.ts\" \"vitest.config.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:canvas-real": "playwright test --grep @real-canvas",
    "test:e2e:sakai-real": "playwright test --grep @real-sakai",
    "check": "pnpm check:public-docs && pnpm check:ob3-openapi && pnpm lint && pnpm format:check && pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "@animo-id/oid4vci": "^0.1.4",
    "@cloudflare/workers-types": "^4.20260206.0",
    "@playwright/test": "^1.58.2",
    "@sphereon/oid4vci-client": "^0.20.1",
    "@types/jsonld": "^1.5.15",
    "@types/pg": "^8.16.0",
    "oxfmt": "0.41.0",
    "oxlint": "1.56.0",
    "oxlint-tsgolint": "0.17.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.7",
    "wrangler": "^4.2.1"
  },
  "dependencies": {
    "better-auth": "1.5.5"
  }
}
